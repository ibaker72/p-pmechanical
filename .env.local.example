# --- Site ---
NEXT_PUBLIC_SITE_URL=https://ppmechanicalllc.com

# --- Supabase (lead storage) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
OWNER_EMAIL=

# --- Admin protection for /api/leads/list ---
ADMIN_SECRET=

# --- Rate limiting + idempotency (Upstash Redis) ---
# Required in production. Without these, the lead API still works but skips
# rate limiting and idempotency — fine for dev, risky in prod.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Webhook authentication ---
# If set, the /api/leads/webhook route requires X-Webhook-Secret to match.
# Leave blank to accept unauthenticated webhooks (rate-limited by IP).
WEBHOOK_SECRET=

# --- Outbound webhook (OpenClaw / n8n / Make / Zapier) ---
# Where to POST `lead.created` events. Payload is signed with HMAC-SHA256
# in the X-Signature header using OUTBOUND_WEBHOOK_SECRET.
OUTBOUND_WEBHOOK_URL=
OUTBOUND_WEBHOOK_SECRET=

# --- Optional: business contact info exposed to the client ---
NEXT_PUBLIC_BUSINESS_PHONE=+1-201-456-5151
NEXT_PUBLIC_BUSINESS_PHONE_DISPLAY=(201) 456-5151

# --- OpenClaw (server-side AI gateway for lead automation / prompts) ---
# All OpenClaw calls happen server-side. OPENCLAW_API_KEY is NEVER exposed to
# the browser. When OPENCLAW_ENABLED is not "true" (or URL/key are missing),
# every OpenClaw feature degrades to a clean fallback and the lead form still
# works exactly as before.
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_MODEL=gpt-4o-mini
OPENCLAW_TIMEOUT_MS=15000
# Optional: override if your gateway uses a non-OpenAI chat route.
OPENCLAW_CHAT_PATH=/v1/chat/completions
# Optional: if set, internal OpenClaw routes require x-internal-secret to match.
OPENCLAW_INTERNAL_SECRET=
